# Copy this file to .env if you want shell helpers later, but do not commit real keys.

# Provider options: ollama or openai
NOTELY_LLM_PROVIDER=ollama

# Ollama local setup
OLLAMA_BASE_URL=http://localhost:11434
NOTELY_LLM_MODEL=llama3.1:8b

# OpenAI setup
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# NOTELY_LLM_MODEL=gpt-4.1-mini

# Agent behavior
NOTELY_LLM_TEMPERATURE=0
NOTELY_MAX_TOOL_ROUNDS=4
